    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogTitle": "# Release Notes\n---",
        "changelogFile": "docs/changelog.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "poetry lock && ./scripts/build.sh",
        "publishCmd": "./scripts/publish.sh"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          "packages/astx/dist/*.whl",
          "packages/astx/dist/*.tar.gz",
          "packages/irx/dist/*.whl",
          "packages/irx/dist/*.tar.gz",
          "packages/arx/dist/*.whl",
          "packages/arx/dist/*.tar.gz",
          "packages/pyarx/dist/*.whl",
          "packages/pyarx/dist/*.tar.gz",
          "packages/aix/dist/*.whl",
          "packages/aix/dist/*.tar.gz",
          "packages/arxjit/dist/*.whl",
          "packages/arxjit/dist/*.tar.gz"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "pyproject.toml",
          "poetry.lock",
          "docs/changelog.md",
          "packages/astx/pyproject.toml",
          "packages/astx/src/astx/__init__.py",
          "packages/irx/pyproject.toml",
          "packages/irx/src/irx/__init__.py",
